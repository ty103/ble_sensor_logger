source "Kconfig.zephyr"

menu "BLE Sensor Logger"

config BSL_IKS01A2_I2C_PROBE
	bool "Enable X-NUCLEO-IKS01A2 I2C probe logging"
	depends on I2C && SENSOR
	default n
	help
	  Enable boot-time sensor API checks and periodic raw WHO_AM_I reads on
	  the X-NUCLEO-IKS01A2 Arduino I2C bus. This is intended for bring-up,
	  logic analyzer, and RTT/VCOM diagnostics, not for normal streaming
	  firmware.

config BSL_ORIENTATION_FRONT_AXIS
	string "Device front axis for LSM6DSL orientation stream"
	default "+X"
	help
	  Select the LSM6DSL raw accelerometer axis that points toward the
	  device front direction. Valid values are +X, -X, +Y, -Y, +Z, and -Z.

config BSL_ORIENTATION_GRAVITY_AXIS
	string "Device gravity axis for LSM6DSL orientation stream"
	default "+Z"
	help
	  Select the LSM6DSL raw accelerometer axis that matches the gravity
	  direction in the reference posture. Valid values are +X, -X, +Y, -Y,
	  +Z, and -Z. This must not use the same physical axis as the front
	  axis.

config BSL_GYRO_CALIB_THRESHOLD_MDPS
	int "Gyro auto-calibration still threshold in mdps"
	default 50
	range 10 1000
	help
	  Per-axis threshold in milli-degrees-per-second. The auto-calibration
	  considers the device still when all three calibrated gyro axes stay
	  within this threshold for the configured window of consecutive samples.

config BSL_GYRO_CALIB_ALPHA_PERMILLE
	int "Gyro auto-calibration bias lerp rate in permille"
	default 5
	range 0 1000
	help
	  IIR coefficient for gradually applying the bias offset, expressed as
	  permille (0-1000 maps to 0.000-1.000). A lower value makes corrections
	  smoother and slower. Default 5 (0.005 per sample at 26 Hz).

config BSL_GYRO_CALIB_WINDOW_SAMPLES
	int "Gyro auto-calibration consecutive still samples required"
	default 26
	range 5 260
	help
	  Number of consecutive samples the device must remain still before the
	  bias update is applied. At 26 Hz the default of 26 corresponds to
	  approximately 1 second.

endmenu
